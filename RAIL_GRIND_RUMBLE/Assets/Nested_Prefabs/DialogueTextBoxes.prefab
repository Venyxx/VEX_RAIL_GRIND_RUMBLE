  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f0389e38ff7ed114ba5941c0962b63c0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    name: Ariadna
    paragraphs:
    - Mama Vera always has such wisdom, I have to come to the orphanage more often.
      Until then though, I have to get home ASAP! Tengo hambre!
    - I should switch to my skates to get home quicker! (Press in the Left Analog
      Stick or Tab)
