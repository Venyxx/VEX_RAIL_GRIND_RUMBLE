  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f0389e38ff7ed114ba5941c0962b63c0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    name: Ariadna
    paragraphs:
    - Grinding on the rails can help build speed, but the roofs would be the fastest
      route over here. Is there anywhere I can grapple to? (Use Left Trigger or Left
      Shift to aim your grappling hook)
    - Anywhere else? (While aiming [LT], use Left or Right Bumper to cycle through
      potential grapple points. When ready, use Right Trigger to shoot the grappling
      hook!)
